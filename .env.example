# Server
NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=real_estate_marketplace
DB_POOL_LIMIT=10

# JWT — must be at least 32 random characters
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Cloudinary (optional — leave blank to use placeholder images in dev)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (optional — leave blank to skip email sending in dev)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@estatehub.com

# CORS — set to your frontend URL in production (Live Server often uses port 5500)
CORS_ORIGIN=http://localhost:5500

# Frontend base URL (password reset, email verification, inquiry links)
FRONTEND_URL=http://localhost:5500

# Set to true to block login until email_verified = 1
REQUIRE_EMAIL_VERIFICATION=false

# Bcrypt
BCRYPT_SALT_ROUNDS=12
